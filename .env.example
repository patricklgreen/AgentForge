# Application
APP_NAME=AgentForge
APP_ENV=development
SECRET_KEY=your-secret-key-min-32-chars-here
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://agentforge:password@localhost:5432/agentforge
DATABASE_SYNC_URL=postgresql+psycopg://agentforge:password@localhost:5432/agentforge

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_FAST_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0

# S3
S3_BUCKET_NAME=agentforge-artifacts-dev

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
